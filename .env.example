# Required - one or more "caller:secret:scope" triples, comma-separated.
# scope is mandatory as of v2 - tokens without a scope are rejected at startup.
#   work     -> can reach sections: work, shared
#   personal -> can reach sections: personal, shared
#   shared   -> can reach section:  shared only
# Every tool call is checked server-side against the token's scope; out-of-scope
# requests get a 403 and are written to the audit_log table along with every
# allowed call (never silently ignored).
#
# Generate a secret with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ATLAS_TOKEN=work-caller:changeme-work:work,personal-caller:changeme-personal:personal

# Optional - defaults shown
PORT=7784
ATLAS_DB_PATH=/app/data/atlas.db
